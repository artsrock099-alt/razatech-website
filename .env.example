# ================================================
# RAZATECH v4 — Environment Variables
# ================================================
#
# LOCAL DEVELOPMENT
# -----------------
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your local MySQL credentials below
# 3. Run: npm start
#    The server auto-creates the DB and all tables.
#
# RAILWAY (PRODUCTION BACKEND)
# ----------------------------
# Set these in Railway → your service → Variables tab.
# Railway MySQL plugin auto-provides MYSQLHOST,
# MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT.
# You only need to manually add the ones below marked
# with [MANUAL].
#
# VERCEL (PRODUCTION FRONTEND)
# ----------------------------
# No env vars needed on Vercel — the frontend is
# static HTML. Just update public/js/config.js with
# your Railway backend URL before deploying.
# ================================================

# ── Server ──────────────────────────────────────
PORT=5000

# Set to 'production' on Railway (add this manually)
NODE_ENV=development                    # [MANUAL on Railway: production]

# ── MySQL — Local Dev ───────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=razatech_db
DB_PORT=3306

# ── MySQL — Railway auto-provides these ─────────
# (Do NOT set these manually on Railway — the MySQL
#  plugin injects them automatically)
# MYSQLHOST=...
# MYSQLUSER=...
# MYSQLPASSWORD=...
# MYSQLDATABASE=...
# MYSQLPORT=...

# ── CORS ────────────────────────────────────────
# Set to your Vercel frontend URL in production.
# Multiple origins: comma-separated, no spaces.
# Example: https://razatech.vercel.app,https://www.razatech.com
ALLOWED_ORIGIN=*                        # [MANUAL on Railway: https://your-app.vercel.app]
