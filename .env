# ================================================
# RAZATECH v4 — Environment Variables
# ================================================
# STEP 1: Copy this file and rename it to ".env"
#         cp .env.example .env
#
# STEP 2: Fill in your MySQL password below
#
# STEP 3: Run:  npm start
#         The server will auto-create the database
#         and all tables — no SQL commands needed!
# ================================================

PORT=5000

# MySQL credentials
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Razak+10
DB_NAME=razatech_db
DB_PORT=3306

# CORS — set to your domain when deploying
ALLOWED_ORIGIN=*
